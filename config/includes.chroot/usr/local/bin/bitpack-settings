#!/usr/bin/env python3
import os
import subprocess
import tkinter as tk
from tkinter import ttk, messagebox

APP_TITLE = "Bitpack Settings"

BITPACK_DIR = "/usr/local/bitpack"
WALLPAPER_DIR = os.path.join(BITPACK_DIR, "wallpapers")
FALLBACK_WALLPAPER = "/usr/share/backgrounds/bitpack-default.jpg"

DESKTOP_FILE = os.path.join(os.path.expanduser("~"), "Desktop")

class App(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title(APP_TITLE)
        self.geometry("520x320")

        self.notebook = ttk.Notebook(self)
        self.notebook.pack(fill="both", expand=True)

        self.tab_firewall = ttk.Frame(self.notebook)
        self.tab_wallpaper = ttk.Frame(self.notebook)
        self.tab_updates = ttk.Frame(self.notebook)

        self.notebook.add(self.tab_firewall, text="Firewall")
        self.notebook.add(self.tab_wallpaper, text="Wallpaper")
        self.notebook.add(self.tab_updates, text="Updates")

        self._build_firewall_tab()
        self._build_wallpaper_tab()
        self._build_updates_tab()

    def run_cmd(self, cmd):
        return subprocess.run(cmd, check=False, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)

    def _build_firewall_tab(self):
        frm = ttk.Frame(self.tab_firewall, padding=16)
        frm.pack(fill="both", expand=True)

        self.fw_status = tk.StringVar(value="Checking UFW...")
        ttk.Label(frm, textvariable=self.fw_status).pack(anchor="w")
        ttk.Separator(frm).pack(fill="x", pady=12)

        self.fw_enabled = self._ufw_enabled()
        btn_txt = "Disable Firewall" if self.fw_enabled else "Enable Firewall"
        self.toggle_btn = ttk.Button(frm, text=btn_txt, command=self.toggle_firewall)
        self.toggle_btn.pack(anchor="w")

        self.refresh_btn = ttk.Button(frm, text="Refresh", command=self.refresh)
        self.refresh_btn.pack(anchor="w", pady=(8,0))

        self.refresh()

    def _ufw_enabled(self):
        res = self.run_cmd(["/usr/sbin/ufw", "status"])
        txt = (res.stdout or "").lower()
        return "active" in txt

    def refresh(self):
        try:
            enabled = self._ufw_enabled()
            self.fw_enabled = enabled
            self.fw_status.set("UFW is enabled" if enabled else "UFW is disabled")
            self.toggle_btn.config(text=("Disable Firewall" if enabled else "Enable Firewall"))
        except Exception as e:
            self.fw_status.set(f"UFW status unavailable: {e}")

    def toggle_firewall(self):
        try:
            if not self.fw_enabled:
                # Enable
                res = self.run_cmd(["pkexec", "ufw", "--force", "enable"])
            else:
                # Disable
                res = self.run_cmd(["pkexec", "ufw", "--force", "disable"])

            if res.returncode != 0:
                raise RuntimeError(res.stdout)
            self.refresh()
            messagebox.showinfo(APP_TITLE, "Firewall setting updated.")
        except Exception as e:
            messagebox.showerror(APP_TITLE, f"Failed to update firewall:\n{e}")

    def _build_wallpaper_tab(self):
        frm = ttk.Frame(self.tab_wallpaper, padding=16)
        frm.pack(fill="both", expand=True)

        ttk.Label(frm, text="Select a Bitpack wallpaper:").pack(anchor="w")
        self.wallpaper_var = tk.StringVar(value="")

        self.wallpaper_list = ttk.Combobox(frm, textvariable=self.wallpaper_var, state="readonly", width=60)
        self.wallpaper_list.pack(anchor="w", pady=(8,8))

        self._load_wallpapers()

        ttk.Button(frm, text="Apply Wallpaper", command=self.apply_wallpaper).pack(anchor="w")
        ttk.Separator(frm).pack(fill="x", pady=12)

        ttk.Label(frm, text="If you add images, place them in:").pack(anchor="w")
        ttk.Label(frm, text=WALLPAPER_DIR).pack(anchor="w")

    def _load_wallpapers(self):
        os.makedirs(WALLPAPER_DIR, exist_ok=True)
        files = []
        for fn in os.listdir(WALLPAPER_DIR):
            if fn.lower().endswith((".jpg", ".jpeg", ".png")):
                files.append(fn)
        files.sort()
        if files:
            self.wallpaper_list["values"] = files
            self.wallpaper_var.set(files[0])
        else:
            # No wallpapers; still allow fallback.
            self.wallpaper_list["values"] = ["(none - using system default)"]
            self.wallpaper_var.set("(none - using system default)")

    def apply_wallpaper(self):
        sel = self.wallpaper_var.get()
        if sel.startswith("("):
            img = FALLBACK_WALLPAPER
        else:
            img = os.path.join(WALLPAPER_DIR, sel)

        try:
            # Best-effort apply for XFCE using xfconf-query if present.
            cmd = ["sh", "-lc",
                   f"xfconf-query -c xfce4-desktop -p /backdrop/screen0/monitor0/image-path -s '{img}' || true"]
            self.run_cmd(cmd)
            messagebox.showinfo(APP_TITLE, "Wallpaper applied (best-effort).")
        except Exception as e:
            messagebox.showerror(APP_TITLE, f"Failed to apply wallpaper:\n{e}")

    def _build_updates_tab(self):
        frm = ttk.Frame(self.tab_updates, padding=16)
        frm.pack(fill="both", expand=True)

        self.upd_result = tk.StringVar(value="")
        ttk.Button(frm, text="Check for Updates", command=self.check_updates).pack(anchor="w")
        ttk.Label(frm, textvariable=self.upd_result, wraplength=480).pack(anchor="w", pady=(10,0))

    def check_updates(self):
        try:
            self.upd_result.set("Running apt update...")
            res = self.run_cmd(["pkexec", "apt", "update"])
            out = res.stdout or ""
            if res.returncode != 0:
                self.upd_result.set(f"Update check failed:\n{out}")
            else:
                # Show a short summary.
                lines = [l for l in out.splitlines() if "upgraded" in l.lower() or "packages can be upgraded" in l.lower()]
                if not lines:
                    lines = out.splitlines()[-8:]
                self.upd_result.set("\n".join(lines) if lines else "Update check completed.")
        except Exception as e:
            self.upd_result.set(f"Failed: {e}")

if __name__ == "__main__":
    App().mainloop()

